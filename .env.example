# Your Telegram bot token (get this from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_token_here

# Comma-separated list of keywords to search for
KEYWORDS=python, wordpress, automation, bot, scraping

# Comma-separated list of keywords to ignore
EXCLUDE_KEYWORDS=logo, design, video

# Minimum budget in USD (jobs below this are ignored)
MIN_BUDGET_USD=10

# Time to send the daily digest (HH:MM format)
DIGEST_TIME=08:00

# Your timezone
TIMEZONE=Asia/Dhaka

# Scraper Toggles (set to false to disable a specific platform)
ENABLE_REMOTEOK=true
ENABLE_PEOPLEPERHOUR=true
ENABLE_FREELANCER=true
ENABLE_GURU=true
ENABLE_UPWORK=true
ENABLE_LINKEDIN=true
ENABLE_FIVERR=true
